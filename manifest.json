{
  "manifest_version": 3,
  "name": "AI Review Assistant",
  "version": "1.0",
  "description": "AI-powered Amazon review generator using Gemini and WordHero",
  "permissions": [
    "tabs",
    "storage",
    "activeTab",
    "scripting",
    "clipboardRead"
  ],
  "host_permissions": [
    "https://www.amazon.com/*",
    "https://api.deepseek.com/*",
    "https://gemini.google.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "AI Review Assistant",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.amazon.com/review/*"],
      "js": ["content-scripts/amazon.js"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}